<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="520.0" prefWidth="520.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.RegisterController">
   <children>
      <VBox layoutX="50.0" layoutY="30.0" prefWidth="420.0" spacing="10.0" style="-fx-padding: 20; -fx-background-color: #000000E3; -fx-background-radius: 10;">
         <children>
            <Label text="Registrazione Cliente" textFill="WHITE" style="-fx-font-size: 22px; -fx-font-weight: bold;" />
            <TextField fx:id="nomeField" promptText="Nome" />
            <TextField fx:id="cognomeField" promptText="Cognome" />
            <TextField fx:id="emailField" promptText="Email" />
            <TextField fx:id="passwordField" promptText="Password" />
            <TextField fx:id="residenzaField" promptText="Residenza" />
            <TextField fx:id="numeroField" promptText="Numero di telefono" />
            <ComboBox fx:id="pianoField" promptText="Piano tariffario" />
            <Button mnemonicParsing="false" onAction="#handleRegistrati" style="-fx-background-color: #007BFF;" text="Registrati" textFill="WHITE" />
            <Button mnemonicParsing="false" onAction="#handleTornaLogin" style="-fx-background-color: #4B5563;" text="Torna al login" textFill="WHITE" />
         </children>
      </VBox>
   </children>
</AnchorPane>
