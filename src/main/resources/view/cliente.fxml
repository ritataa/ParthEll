<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.ClienteController">
   <children>
      <Label fx:id="welcomeLabel" layoutX="250.0" layoutY="30.0" text="Benvenuto Cliente" style="-fx-font-size: 20px;" />

      <VBox layoutX="50.0" layoutY="18.0" spacing="4.0">
         <children>
            <Label fx:id="tipoContoLabel" text="Conto: -" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
            <Label fx:id="dettagliContoLabel" text="-" wrapText="true" prefWidth="420.0" />
         </children>
      </VBox>
      
      <TabPane layoutX="50.0" layoutY="90.0" prefHeight="390.0" prefWidth="500.0">
         <tabs>
            <Tab text="Servizi">
               <content>
                  <VBox spacing="15.0" style="-fx-padding: 20;">
                     <children>
                        <HBox spacing="10.0">
                           <children>
                              <TextField fx:id="numeroField" promptText="Numero di telefono" />
                              <TextField fx:id="durataField" promptText="Durata (min)" />
                              <Button fx:id="effettuaChiamataButton" onAction="#handleEffettuaChiamata" text="Chiama" />
                           </children>
                        </HBox>
                        
                        <HBox spacing="10.0">
                           <children>
                              <TextField fx:id="numeroSmsField" promptText="Numero di telefono" />
                              <TextField fx:id="testoSmsField" promptText="Testo SMS" />
                              <Button fx:id="inviaSmsButton" onAction="#handleInviaSms" text="Invia SMS" />
                           </children>
                        </HBox>
                        
                        <HBox spacing="10.0">
                           <children>
                              <TextField fx:id="datiField" promptText="GB da utilizzare" />
                              <Button fx:id="usaDatiButton" onAction="#handleUsaDati" text="Usa Dati" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </Tab>
            
            <Tab text="Promozioni">
               <content>
                  <VBox spacing="10.0" style="-fx-padding: 10;">
                     <children>
                        <Label text="Promozioni Disponibili" style="-fx-font-size: 16px;" />
                        <TableView fx:id="promozioniTable" prefHeight="250.0">
                           <columns>
                              <TableColumn fx:id="nomePromozioneColumn" text="Nome" />
                              <TableColumn fx:id="descrizioneColumn" text="Descrizione" />
                           </columns>
                        </TableView>
                        <HBox spacing="10.0">
                           <children>
                              <Button fx:id="aderisciPromozioneButton" onAction="#handleAderisciPromozione" text="Aderisci Promozione" />
                              <Button fx:id="disdiciPromozioneButton" onAction="#handleDisdiciPromozione" text="Disdici Promozione" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </Tab>
            
            <Tab text="Wallet">
               <content>
                  <VBox spacing="10.0" style="-fx-padding: 10;">
                     <children>
                        <Label text="Wallet e Pagamenti" style="-fx-font-size: 16px;" />
                        
                        <!-- Sezione Pagamenti per Ricaricabile -->
                        <VBox fx:id="pagamentiRicaricabileBox" spacing="10.0">
                           <children>
                              <Label text="Metodi di Pagamento (Ricarica)" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                              <HBox spacing="10.0">
                                 <children>
                                    <Button fx:id="pagamentoContantiButton" onAction="#handlePagamentoContanti" text="Contanti" />
                                    <Button fx:id="pagamentoCartaButton" onAction="#handlePagamentoCarta" text="Carta" />
                                    <Button fx:id="pagamentoBancomatButton" onAction="#handlePagamentoBancomat" text="Bancomat" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        
                        <!-- Sezione Wallet per Fisso -->
                        <VBox fx:id="walletFissoBox" spacing="10.0">
                           <children>
                              <Label text="Dati Addebito Automatico" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
                              <HBox spacing="8.0">
                                 <children>
                                    <Label text="Tipo Conto:" style="-fx-font-weight: bold;" />
                                    <Label fx:id="walletTipoContoLabel" text="-" />
                                 </children>
                              </HBox>
                              <HBox spacing="8.0">
                                 <children>
                                    <Label text="Addebito Automatico:" style="-fx-font-weight: bold;" />
                                    <Label fx:id="walletAddebitoLabel" text="Abilitato" />
                                 </children>
                              </HBox>
                              <Label text="Intestatario Carta" style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                              <Label fx:id="walletIntestatarioLabel" text="-" />
                              <Label text="Numero Carta" style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                              <Label fx:id="walletNumeroCartaLabel" text="-" />
                              <Label text="Scadenza" style="-fx-font-size: 12px; -fx-font-weight: bold;" />
                              <Label fx:id="walletScadenzaLabel" text="-" />
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </content>
            </Tab>

            <Tab text="Situazione Attuale">
               <content>
                  <VBox spacing="12.0" style="-fx-padding: 16;">
                     <children>
                        <Label text="Riepilogo abbonato" style="-fx-font-size: 16px;" />
                        <HBox spacing="8.0">
                           <children>
                              <Label text="Numero:" style="-fx-font-weight: bold;" />
                              <Label fx:id="numeroAttualeLabel" text="-" />
                           </children>
                        </HBox>
                        <HBox spacing="8.0">
                           <children>
                              <Label text="Piano attivo:" style="-fx-font-weight: bold;" />
                              <Label fx:id="pianoAttivoLabel" text="-" />
                           </children>
                        </HBox>
                        <HBox spacing="8.0">
                           <children>
                              <Label text="Minuti usati:" style="-fx-font-weight: bold;" />
                              <Label fx:id="chiamateUsateLabel" text="0" />
                           </children>
                        </HBox>
                        <HBox spacing="8.0">
                           <children>
                              <Label text="SMS inviati:" style="-fx-font-weight: bold;" />
                              <Label fx:id="smsUsatiLabel" text="0" />
                           </children>
                        </HBox>
                        <HBox spacing="8.0">
                           <children>
                              <Label text="Dati usati:" style="-fx-font-weight: bold;" />
                              <Label fx:id="datiUsatiLabel" text="0 GB" />
                           </children>
                        </HBox>
                        <HBox spacing="8.0">
                           <children>
                              <Label text="Minuti residui:" style="-fx-font-weight: bold;" />
                              <Label fx:id="minutiResiduiLabel" text="-" />
                           </children>
                        </HBox>
                        <HBox spacing="8.0">
                           <children>
                              <Label text="Giga residui:" style="-fx-font-weight: bold;" />
                              <Label fx:id="gigaResiduiLabel" text="-" />
                           </children>
                        </HBox>
                        <HBox spacing="8.0">
                           <children>
                              <Label text="Promozioni attive:" style="-fx-font-weight: bold;" />
                              <Label fx:id="promozioniAttiveLabel" text="Nessuna" wrapText="true" prefWidth="340.0" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </Tab>

            <Tab text="Storico Pagamenti">
               <content>
                  <StackPane style="-fx-padding: 10;">
                     <children>
                        <VBox fx:id="storicoClassicoPane" spacing="10.0" visible="true" managed="true">
                           <children>
                              <Label text="Storico Pagamenti Mensili" style="-fx-font-size: 16px;" />
                              <TableView fx:id="storicoPagamentiTable" prefHeight="320.0">
                                 <columns>
                                    <TableColumn fx:id="mesePagamentoColumn" text="Mese" prefWidth="120.0" />
                                    <TableColumn fx:id="annoPagamentoColumn" text="Anno" prefWidth="90.0" />
                                    <TableColumn fx:id="importoPagamentoColumn" text="Importo" prefWidth="120.0" />
                                    <TableColumn fx:id="promoPagamentoColumn" text="Promo" prefWidth="160.0" />
                                    <TableColumn fx:id="statoPagamentoColumn" text="Stato" prefWidth="120.0" />
                                 </columns>
                              </TableView>
                              <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                 <children>
                                    <Button fx:id="dettagliStoricoButton" onAction="#handleMostraDettagliStorico" text="Dettagli" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>

                        <VBox fx:id="storicoDettaglioPane" spacing="12.0" visible="false" managed="false" style="-fx-background-color: #1C1C1E; -fx-background-radius: 8; -fx-padding: 18;">
                           <children>
                              <Label text="Dettaglio Pagamento" style="-fx-font-size: 18px; -fx-font-weight: bold;" textFill="WHITE" />
                              <HBox spacing="8.0">
                                 <children>
                                    <Label text="Mese:" textFill="WHITE" />
                                    <Label fx:id="dettaglioMeseLabel" text="-" textFill="WHITE" />
                                 </children>
                              </HBox>
                              <HBox spacing="8.0">
                                 <children>
                                    <Label text="Anno:" textFill="WHITE" />
                                    <Label fx:id="dettaglioAnnoLabel" text="-" textFill="WHITE" />
                                 </children>
                              </HBox>
                              <HBox spacing="8.0">
                                 <children>
                                    <Label text="Importo:" textFill="WHITE" />
                                    <Label fx:id="dettaglioImportoLabel" text="-" textFill="WHITE" />
                                 </children>
                              </HBox>
                              <HBox spacing="8.0">
                                 <children>
                                    <Label text="Stato:" textFill="WHITE" />
                                    <Label fx:id="dettaglioStatoLabel" text="-" textFill="WHITE" />
                                 </children>
                              </HBox>
                              <Label text="Promo completa" textFill="WHITE" />
                              <TextArea fx:id="dettaglioPromoArea" editable="false" wrapText="true" prefHeight="150.0" />
                              <HBox alignment="CENTER_RIGHT" spacing="10.0">
                                 <children>
                                    <Button fx:id="pagaDaSaldoButton" onAction="#handlePagaDaSaldoDettaglio" text="Paga" />
                                    <Button fx:id="indietroStoricoButton" onAction="#handleIndietroStorico" text="Indietro" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </StackPane>
               </content>
            </Tab>
         </tabs>
      </TabPane>
      
      <Button fx:id="logoutButton" layoutX="500.0" layoutY="20.0" onAction="#handleLogout" text="Logout" />
   </children>
</AnchorPane>
